datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 👤 CORE ENTITIES (USERS & AUTHENTICATION)
// ==========================================

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password_hash String
  created_at    DateTime      @default(now())
  products      Product[]
  sales         Sale[]
  customers     Customer[] 
  refresh_token RefreshToken? 
  categories    Category[]    

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  expires_in Int      // Expiration time stored as a Unix Timestamp
  created_at DateTime @default(now())
  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==========================================
// 📦 OPERATIONAL ENTITIES (CATALOG & CRM)
// ==========================================

model Category {
  id         String    @id @default(uuid())
  name       String
  created_at DateTime  @default(now())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  products   Product[]

  @@map("categories")
}

model Product {
  id             String     @id @default(uuid())
  name           String
  description    String?
  price          Decimal    @db.Decimal(10, 2)
  stock_quantity Int
  user_id        String
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sale_items     SaleItem[]
  category_id    String?    
  category       Category?  @relation(fields: [category_id], references: [id], onDelete: SetNull)

  @@map("products")
}

model Customer {
  id         String   @id @default(uuid())
  name       String
  email      String?  // Optional for quick over-the-counter registration
  phone      String?
  created_at DateTime @default(now())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sales      Sale[]   // Customer sales history inside CRM

  @@map("customers")
}

// ==========================================
// 💰 TRANSACTIONAL ENTITIES (SALES ENGINE)
// ==========================================

model Sale {
  id            String     @id @default(uuid())
  customer_name String?    // Kept for free-text backward compatibility
  total_price   Decimal    @db.Decimal(10, 2)
  created_at    DateTime   @default(now())
  user_id       String
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  customer_id   String?    // Optional Foreign Key linked to CRM
  customer      Customer?  @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  sale_items    SaleItem[]

  @@map("sales")
}

model SaleItem {
  id            String   @id @default(uuid())
  quantity      Int
  price_at_sale Decimal  @db.Decimal(10, 2)
  sale_id       String
  sale          Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product_id    String
  product       Product  @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@map("sale_items")
}
